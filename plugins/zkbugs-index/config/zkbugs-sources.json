{
  "upstream": {
    "repo_url": "https://github.com/zksecurity/zkbugs",
    "local_path": null,
    "branch": "main",
    "entry_glob": "**/*.json",
    "exclude_paths": [".github", ".vscode", "node_modules", "package.json", "package-lock.json", "reports"]
  },
  "org": {
    "repo_url": null,
    "local_path": null,
    "branch": "main"
  },
  "supplemental_files": [
    "./data/external_findings/trail-of-bits.json",
    "./data/external_findings/zellic.json",
    "./data/external_findings/audit-contests.json"
  ],
  "index_dir": "./index",
  "cache_dir": "./.cache",
  "semantic_search": {
    "enabled": false,
    "model": "all-MiniLM-L6-v2"
  }
}
